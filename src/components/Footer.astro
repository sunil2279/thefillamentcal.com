---
// Footer.astro — premium Vercel-style footer
const year = new Date().getFullYear();
---

<footer id="site-footer">
  <div class="footer-inner">
    
    <div class="footer-grid">
      <!-- Brand & Status -->
      <div class="footer-col footer-col-brand">
        <a href="/" class="footer-brand">
          <img src="/logo.png" height="24" alt="TheFilamentCalc logo" class="logo" />
          <span>TheFilamentCalc</span>
        </a>
        <p class="footer-tagline">
          Convert 3D print weight to length instantly. Free, browser-based, and privacy-first.
        </p>
        <div class="status-indicator">
          <span class="status-dot-pulse"></span>
          <span class="status-text">Privacy-first & client-side</span>
        </div>
      </div>

      <!-- Tools -->
      <div class="footer-col">
        <h4 class="footer-title">Tools</h4>
        <nav class="footer-nav">
          <a href="/#calculator">Grams to Meters</a>
          <a href="/#chart">Density Chart</a>
          <a href="/#docs">Calculator Guide</a>
          <a href="/#faq">FAQ</a>
        </nav>
      </div>

      <!-- Company -->
      <div class="footer-col">
        <h4 class="footer-title">Company</h4>
        <nav class="footer-nav">
          <a href="/about">About Us</a>
          <a href="/contact">Contact</a>
        </nav>
      </div>

      <!-- Legal -->
      <div class="footer-col">
        <h4 class="footer-title">Legal</h4>
        <nav class="footer-nav">
          <a href="/privacy">Privacy Policy</a>
          <a href="/terms">Terms of Service</a>
        </nav>
      </div>
    </div>

    <div class="footer-bottom">
      <span class="footer-copy">
        &copy; {year} TheFilamentCalc. All rights reserved.
      </span>
    </div>

  </div>
</footer>

<style>
  #site-footer {
    background: var(--bg);
    border-top: 1px solid var(--border);
    transition: background 0.2s ease, border-color 0.2s ease;
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: var(--spacing-4xl) 24px var(--spacing-3xl);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
    margin-bottom: var(--spacing-2xl);
  }

  .footer-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .footer-col-brand {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--spacing-md);
  }

  .footer-brand {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--spacing-xs);
    text-decoration: none;
    color: var(--fg);
    font-size: 14px;
    font-weight: 600;
    letter-spacing: -0.28px;
  }

  .logo {
    border-radius: 4px;
  }

  html.dark .logo {
    filter: invert();
  }

  .footer-tagline {
    font-size: 13px;
    line-height: 20px;
    color: var(--fg-body);
    max-width: 280px;
    margin: 0;
  }

  /* Status Pill Indicator */
  .status-indicator {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 4px 10px;
    border-radius: 9999px;
    border: 1px solid rgba(10, 124, 78, 0.15);
    background: rgba(10, 124, 78, 0.03);
    color: #0a7c4e;
    font-size: 11px;
    font-weight: 500;
    font-family: var(--font-mono);
  }

  html.dark .status-indicator {
    border-color: rgba(80, 227, 194, 0.15);
    background: rgba(80, 227, 194, 0.03);
    color: #50e3c2;
  }

  .status-dot-pulse {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: #0a7c4e;
    position: relative;
  }

  html.dark .status-dot-pulse {
    background-color: #50e3c2;
  }

  .status-dot-pulse::after {
    content: '';
    position: absolute;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    background-color: inherit;
    animation: status-pulse 2s infinite ease-out;
    opacity: 0.8;
  }

  @keyframes status-pulse {
    0% {
      transform: scale(1);
      opacity: 0.8;
    }
    100% {
      transform: scale(3.5);
      opacity: 0;
    }
  }

  .footer-title {
    font-size: 12px;
    font-weight: 600;
    color: var(--fg);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0 0 var(--spacing-sm);
    font-family: var(--font-mono);
  }

  .footer-nav {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-xs);
  }

  .footer-nav a {
    font-size: 13px;
    color: var(--fg-mute);
    text-decoration: none;
    transition: color 0.12s;
  }

  .footer-nav a:hover {
    color: var(--fg);
  }

  /* Bottom Area */
  .footer-bottom {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-md);
    border-top: 1px solid var(--border);
    padding-top: var(--spacing-lg);
    margin-top: var(--spacing-xl);
  }

  .footer-copy {
    font-size: 12px;
    color: var(--fg-mute);
  }

  .footer-socials {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .footer-socials a {
    color: var(--fg-mute);
    transition: color 0.12s, transform 0.12s;
    display: flex;
    align-items: center;
  }

  .footer-socials a:hover {
    color: var(--fg);
    transform: translateY(-1px);
  }

  /* Responsive breakpoints */
  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 32px;
    }
    .footer-col-brand {
      grid-column: span 2;
    }
  }

  @media (max-width: 480px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: var(--spacing-lg);
    }
    .footer-col-brand {
      grid-column: span 1;
    }
  }
</style>
