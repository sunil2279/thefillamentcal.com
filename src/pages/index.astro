<!-- ═══════════════════════════════════════════════════════════
     JAVASCRIPT ENGINE
═══════════════════════════════════════════════════════════ -->
<script>
  // ── Constants ──
  const RADIUS_CM = 0.0875; // 1.75mm / 2 in cm
  const VOL_PER_METER = Math.PI * RADIUS_CM * RADIUS_CM * 100; // cm³/m
  const METERS_TO_FEET = 3.28084;
  const MAX_RECENT = 5;
  const RECENT_KEY = 'tfc_recent_grams';

  const MATERIALS = {
    pla:  { label: 'PLA',  density: 1.24 },
    abs:  { label: 'ABS',  density: 1.04 },
    petg: { label: 'PETG', density: 1.27 },
    tpu:  { label: 'TPU',  density: 1.21 },
  };

  // ── DOM refs ──
  const gramsInput    = document.getElementById('grams-input');
  const materialSel   = document.getElementById('material-select');
  const spoolPrice    = document.getElementById('spool-price');
  const spoolWeight   = document.getElementById('spool-weight');
  const resMeters     = document.getElementById('res-meters');
  const resFeet       = document.getElementById('res-feet');
  const resCost       = document.getElementById('res-cost');
  const resCostSub    = document.getElementById('res-cost-sub');
  const resPct        = document.getElementById('res-pct');
  const resPctSub     = document.getElementById('res-pct-sub');
  const resPrints     = document.getElementById('res-prints');
  const resPrintsSub  = document.getElementById('res-prints-sub');
  const spoolBarFill  = document.getElementById('spool-bar-fill');
  const spoolBarLabel = document.getElementById('spool-bar-label');
  const recentChips   = document.getElementById('recent-chips');
  const chartTbody    = document.getElementById('chart-tbody');

  // ── Helpers ──
  function fmt(n, decimals = 2) {
    if (!isFinite(n)) return '—';
    return n.toLocaleString('en-US', { minimumFractionDigits: decimals, maximumFractionDigits: decimals });
  }

  function weightPerMeter(density) {
    return VOL_PER_METER * density; // g/m
  }

  function gramsToMeters(grams, density) {
    return grams / weightPerMeter(density);
  }

  // ── Core calculation ──
  function calculate() {
    const grams   = parseFloat(gramsInput.value);
    const mat     = MATERIALS[materialSel.value];
    const price   = parseFloat(spoolPrice.value) || 0;
    const sWeight = parseFloat(spoolWeight.value) || 1000;

    const costPerGram = price / sWeight;
    resCostSub.textContent = `at $${costPerGram.toFixed(3)}/g`;
    resPctSub.textContent  = `of ${sWeight.toLocaleString()}g spool`;
    resPrintsSub.textContent = `prints from full spool`;

    if (!grams || grams <= 0 || isNaN(grams)) {
      resMeters.textContent = '—';
      resFeet.textContent   = '—';
      resCost.textContent   = '—';
      resPct.textContent    = '—';
      resPrints.textContent = '—';
      spoolBarFill.style.width = '0%';
      spoolBarLabel.textContent = '0% of spool used';
      return;
    }

    const meters  = gramsToMeters(grams, mat.density);
    const feet    = meters * METERS_TO_FEET;
    const cost    = grams * costPerGram;
    const pct     = Math.min((grams / sWeight) * 100, 100);
    const prints  = sWeight / grams;

    resMeters.textContent = fmt(meters);
    resFeet.textContent   = fmt(feet);
    resCost.textContent   = '$' + fmt(cost);
    resPct.textContent    = fmt(pct, 1) + '%';
    resPrints.textContent = fmt(prints, 1);

    spoolBarFill.style.width = pct + '%';
    spoolBarLabel.textContent = fmt(pct, 1) + '% of spool used';
  }

  // ── Recent chips ──
  function getRecent() {
    try { return JSON.parse(localStorage.getItem(RECENT_KEY)) || []; }
    catch { return []; }
  }

  function saveRecent(val) {
    let recent = getRecent().filter(v => v !== val);
    recent.unshift(val);
    recent = recent.slice(0, MAX_RECENT);
    localStorage.setItem(RECENT_KEY, JSON.stringify(recent));
  }

  function renderRecentChips() {
    const recent = getRecent();
    recentChips.innerHTML = '';
    recent.forEach(val => {
      const btn = document.createElement('button');
      btn.className = 'chip recent';
      btn.textContent = val + 'g';
      btn.dataset.g = val;
      btn.addEventListener('click', () => {
        gramsInput.value = val;
        calculate();
      });
      recentChips.appendChild(btn);
    });
  }

  // Save recent on blur if value is valid
  gramsInput.addEventListener('blur', () => {
    const v = parseFloat(gramsInput.value);
    if (v > 0 && isFinite(v)) {
      saveRecent(v);
      renderRecentChips();
    }
  });

  // ── Quick-fill chips ──
  document.querySelectorAll('.chip[data-g]').forEach(btn => {
    btn.addEventListener('click', () => {
      gramsInput.value = btn.dataset.g;
      calculate();
    });
  });

  // ── Copy buttons ──
  document.querySelectorAll('.copy-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const key = btn.dataset.copy;
      const map = {
        meters: resMeters.textContent,
        feet:   resFeet.textContent,
        cost:   resCost.textContent,
        pct:    resPct.textContent,
        prints: resPrints.textContent,
      };
      const text = map[key];
      if (!text || text === '—') return;
      try {
        await navigator.clipboard.writeText(text);
        btn.classList.add('copied');
        setTimeout(() => btn.classList.remove('copied'), 1500);
      } catch {
        // Fallback for older browsers
        const ta = document.createElement('textarea');
        ta.value = text;
        ta.style.position = 'fixed';
        ta.style.opacity = '0';
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        document.body.removeChild(ta);
        btn.classList.add('copied');
        setTimeout(() => btn.classList.remove('copied'), 1500);
      }
    });
  });

  // ── Theme toggle ──
  document.getElementById('theme-toggle').addEventListener('click', () => {
    const isDark = document.documentElement.classList.contains('dark');
    const next = isDark ? 'light' : 'dark';
    document.documentElement.classList.remove('light', 'dark');
    document.documentElement.classList.add(next);
    localStorage.setItem('theme', next);
  });

  // ── Conversion chart ──
  const CHART_WEIGHTS = [1, 5, 10, 25, 50, 100, 150, 200, 250, 500, 750, 1000];

  function buildChart() {
    chartTbody.innerHTML = '';
    CHART_WEIGHTS.forEach(w => {
      const tr = document.createElement('tr');
      const plaM  = gramsToMeters(w, MATERIALS.pla.density);
      const absM  = gramsToMeters(w, MATERIALS.abs.density);
      const petgM = gramsToMeters(w, MATERIALS.petg.density);
      const tpuM  = gramsToMeters(w, MATERIALS.tpu.density);
      const plaFt = plaM * METERS_TO_FEET;
      tr.innerHTML = `
        <td>${w.toLocaleString()}g</td>
        <td>${fmt(plaM)}</td>
        <td>${fmt(absM)}</td>
        <td>${fmt(petgM)}</td>
        <td>${fmt(tpuM)}</td>
        <td>${fmt(plaFt)}</td>
      `;
      chartTbody.appendChild(tr);
    });
  }

  // ── Event listeners ──
  gramsInput.addEventListener('input', calculate);
  materialSel.addEventListener('change', calculate);
  spoolPrice.addEventListener('input', calculate);
  spoolWeight.addEventListener('input', calculate);

  // ── Init ──
  renderRecentChips();
  buildChart();
  calculate();
</script>

</Layout>
