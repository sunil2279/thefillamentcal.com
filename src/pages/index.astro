<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      "name": "TheFilamentCalc — 3D Printer Filament Calculator",
      "url": "https://thefilamentcalc.com/",
      "description": "Free online 3D print weight to length calculator. Convert filament grams to meters and feet for PLA, ABS, PETG, and TPU. Calculate cost per gram and projected print usage in real time.",
      "applicationCategory": "UtilitiesApplication",
      "operatingSystem": "Any",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      },
      "featureList": [
        "Convert 3D printer filament grams to meters",
        "Filament length calculator for PLA, ABS, PETG, TPU",
        "Real-time cost per gram calculation",
        "Projected 3D print usage estimator"
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "How do I convert 3D printer filament grams to meters?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "To convert filament grams to meters, divide the weight in grams by the weight per meter of your filament. For 1.75mm PLA (density 1.24 g/cm³), the weight per meter is approximately 2.98 g/m. So 100g ÷ 2.98 g/m ≈ 33.6 meters. Our calculator does this automatically for PLA, ABS, PETG, and TPU."
          }
        },
        {
          "@type": "Question",
          "name": "How many meters of filament are on a 1kg spool?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A standard 1kg (1000g) spool of 1.75mm PLA contains approximately 335 meters (1099 feet) of filament. For ABS the figure is about 399 meters, for PETG about 327 meters, and for TPU about 343 meters. The difference comes from each material's volumetric density."
          }
        },
        {
          "@type": "Question",
          "name": "What is the formula for filament length from weight?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The formula is: Length (m) = Weight (g) ÷ (π × r² × 100 × density). For 1.75mm filament, the radius r = 0.0875 cm. The cross-sectional volume per meter is π × 0.0875² × 100 ≈ 2.405 cm³/m. Multiply by the material density to get grams per meter, then divide your target weight by that figure."
          }
        },
        {
          "@type": "Question",
          "name": "How do I calculate the cost of filament per gram?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Divide the spool price by the spool weight in grams. For example, a $20 spool of 1000g gives a cost of $0.02 per gram. Multiply that by the grams you plan to use to get the material cost for any print. Our calculator updates this in real time as you type."
          }
        },
        {
          "@type": "Question",
          "name": "Does filament material type affect the length per spool?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. Each material has a different volumetric density, which directly affects how many meters fit on a spool of the same weight. ABS (1.04 g/cm³) is the lightest, giving the most meters per kilogram. PETG (1.27 g/cm³) is the densest of the common materials, giving the fewest meters. PLA (1.24 g/cm³) and TPU (1.21 g/cm³) fall in between."
          }
        }
      ]
    }
  ]
}
</script>

