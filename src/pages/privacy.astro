---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Privacy Policy — TheFilamentCalc"
  description="TheFilamentCalc privacy policy. We collect no personal data. All calculations run locally in your browser."
  canonical="https://thefilamentcalc.com/privacy"
>
  <section class="page-hero">
    <div class="container">
      <div class="page-eyebrow">Legal</div>
      <h1 class="page-title">Privacy Policy</h1>
      <p class="page-lead">Effective date: January 1, 2026</p>
    </div>
  </section>

  <section class="page-body">
    <div class="container prose">

      <h2>Data we collect</h2>
      <p>
        TheFilamentCalc collects <strong>no personal data</strong>. We do not use cookies,
        analytics trackers, or any third-party data collection services.
      </p>

      <h2>localStorage</h2>
      <p>
        The calculator stores your recent filament weight entries and your light/dark theme
        preference in your browser's <code>localStorage</code>. This data never leaves your
        device and is not accessible to us or any third party.
      </p>

      <h2>Third-party fonts</h2>
      <p>
        We load Inter and JetBrains Mono from Google Fonts. Google may log the font request
        (your IP address and browser user-agent) per their own
        <a href="https://policies.google.com/privacy" target="_blank" rel="noopener">Privacy Policy</a>.
      </p>

      <h2>Changes to this policy</h2>
      <p>
        We may update this policy occasionally. The effective date at the top of this page
        will reflect any changes.
      </p>

      <h2>Contact</h2>
      <p>
        Questions? Reach us via the <a href="/about">About</a> page.
      </p>

    </div>
  </section>
</Layout>

<style>
  .page-hero {
    padding: 80px 0 48px;
    background: var(--bg);
    border-bottom: 1px solid var(--border);
  }
  .page-eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: var(--fg-mute);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 12px;
  }
  .page-title {
    font-size: clamp(28px, 4vw, 40px);
    font-weight: 600;
    letter-spacing: -1.5px;
    color: var(--fg);
    margin: 0 0 8px;
    line-height: 1.1;
  }
  .page-lead {
    font-size: 14px;
    color: var(--fg-mute);
    font-family: 'JetBrains Mono', monospace;
    margin: 0;
  }
  .page-body {
    padding: 56px 0 80px;
    background: var(--bg-soft);
  }
  .prose h2 {
    font-size: 18px;
    font-weight: 600;
    letter-spacing: -0.4px;
    color: var(--fg);
    margin: 32px 0 8px;
  }
  .prose p {
    font-size: 16px;
    line-height: 26px;
    color: var(--fg-body);
    margin: 0 0 14px;
    max-width: 680px;
  }
  .prose code {
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    background: var(--bg-soft2);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 1px 5px;
    color: var(--fg);
  }
  .prose a { color: #0070f3; text-decoration: underline; }
</style>
