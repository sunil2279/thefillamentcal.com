---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contact Us — TheFilamentCalc"
  description="Get in touch with the TheFilamentCalc team. We'd love to hear your feedback, questions, or suggestions."
  canonical="https://thefilamentcalc.com/contact"
>
  <div class="page-wrapper">
    <section class="page-hero">
      <div class="page-eyebrow">Contact</div>
      <h1 class="page-title">Get in touch.</h1>
      <p class="page-lead">
        Have a question, found a bug, or want to suggest a feature?
        Fill out the form below and we'll get back to you as soon as we can.
      </p>
    </section>

    <section class="page-body">
      <div class="prose">

        <h2>Send us a message</h2>
        <form class="contact-form" name="contact" method="POST">
          <div class="form-group">
            <label for="name">Name</label>
            <input type="text" id="name" name="name" placeholder="Your name" required />
          </div>

          <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" placeholder="you@example.com" required />
          </div>

          <div class="form-group">
            <label for="message">Message</label>
            <textarea id="message" name="message" rows="5" placeholder="What's on your mind?" required></textarea>
          </div>

          <button type="submit" class="submit-btn">Send Message</button>
        </form>



      </div>
    </section>
  </div>
</Layout>

<style>
  .page-wrapper {
    min-height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 80px 24px;
    background: var(--bg-soft);
  }

  .page-hero {
    width: 100%;
    max-width: 680px;
    text-align: center;
    margin-bottom: 48px;
    padding-bottom: 40px;
    border-bottom: 1px solid var(--border);
  }

  .page-eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: var(--fg-mute);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 12px;
  }

  .page-title {
    font-size: clamp(28px, 4vw, 40px);
    font-weight: 600;
    letter-spacing: -1.5px;
    color: var(--fg);
    margin: 0 0 12px;
    line-height: 1.1;
  }

  .page-lead {
    font-size: 17px;
    line-height: 27px;
    color: var(--fg-body);
    max-width: 520px;
    margin: 0 auto;
  }

  .page-body {
    width: 100%;
    max-width: 680px;
  }

  .prose h2 {
    font-size: 20px;
    font-weight: 600;
    letter-spacing: -0.6px;
    color: var(--fg);
    margin: 36px 0 10px;
  }

  .prose h2:first-child {
    margin-top: 0;
  }

  .prose p {
    font-size: 16px;
    line-height: 26px;
    color: var(--fg-body);
    margin: 0 0 14px;
  }

  .prose a {
    color: #0070f3;
    text-decoration: underline;
  }

  .prose a:hover {
    opacity: 0.8;
  }

  /* Contact form */
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 20px;
    margin-bottom: 14px;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .form-group label {
    font-size: 14px;
    font-weight: 500;
    color: var(--fg);
  }

  .form-group input,
  .form-group textarea {
    font-family: inherit;
    font-size: 14px;
    color: var(--fg);
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 10px 14px;
    outline: none;
    transition: border-color 0.15s;
    resize: vertical;
  }

  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: var(--fg-mute);
  }

  .form-group input:focus,
  .form-group textarea:focus {
    border-color: #0070f3;
  }

  .submit-btn {
    align-self: flex-start;
    font-family: inherit;
    font-size: 14px;
    font-weight: 500;
    color: #fff;
    background: #0070f3;
    border: none;
    border-radius: 8px;
    padding: 10px 20px;
    cursor: pointer;
    transition: opacity 0.15s;
  }

  .submit-btn:hover {
    opacity: 0.85;
  }

  @media (max-width: 600px) {
    .page-wrapper { padding: 48px 16px; }
  }
</style>
